{
  "name": "doc-link-jump",
  "displayName": "Doc Link Jump",
  "description": "Make links in code comments clickable — Ctrl+Click to jump, Ctrl+Alt+Click to open to the side",
  "version": "0.0.1",
  "publisher": "krysl",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "doc-link-jump.reload",
        "title": "Doc Link Jump: Reload Providers"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
